# ============================================
# CampusVision AI — Environment Variables
# Copy this file to .env and fill in secrets
# ============================================
#
# Usage:
#   1. cp .env.example .env
#   2. Fill in actual values for all secrets
#   3. Services will read from environment or .env
#

# --- Required Secrets ---

# JWT signing secret for dormitory-service-go (32+ chars)
# Must match main backend's signing key in production.
# Used by: dormitory-service-go (config.yaml → jwt.secret)
JWT_SECRET=change-me-to-a-256-bit-random-string

# AES-256-GCM encryption key (exactly 32 bytes)
# Used by: stream-gateway + dormitory-service-go for RTSP password encryption
# IMPORTANT: Set the SAME value in both services for cross-module portability.
CAMERA_ENCRYPTION_KEY=change-me-to-a-32-byte-key

# Management API key for stream-gateway (port 8081)
# Sent via X-Management-Key header. Leave empty to disable auth.
# Used by: stream-gateway (management.management_key)
MANAGEMENT_KEY=change-me-to-a-random-string

# Face recognition auth token for matcher API calls
# Sent as Bearer token to dormitory-service-go /api/face/match.
# Used by: face-recognition (match.auth_token)
FACE_AUTH_TOKEN=

# MariaDB root password (used by docker-compose)
MARIADB_ROOT_PASSWORD=root_dev

# MariaDB application user password (used by docker-compose)
MARIADB_PASSWORD=sims

# CORS allowed origins (comma-separated)
# Used by: dormitory-service-go (middleware/cors.go)
CORS_ALLOWED_ORIGINS=http://localhost:8082,http://localhost:8083

# --- Optional Overrides ---

# Kafka broker addresses (comma-separated) for overriding config.yaml
KAFKA_BROKERS=localhost:9092

# Test environment: enable SSE event stream (set to 1 or true)
# See: test-env/internal/server/sse.go
ALLOW_SSE_PUBLIC=1
